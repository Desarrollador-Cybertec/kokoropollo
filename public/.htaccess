Options -Indexes
RewriteEngine On

# Permitir acceso directo a archivos reales (css, img, js)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás pasa por index.php
RewriteRule ^ index.php [QSA,L]

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # A-01: HSTS — forzar HTTPS una vez activado en producción
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # A-01: Permissions Policy
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # A-01: CSP — permite Tailwind CDN, SweetAlert CDN y assets propios
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.tailwindcss.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
    # Eliminar header obsoleto X-XSS-Protection (reemplazado por CSP)
    Header always unset X-XSS-Protection
</IfModule>
