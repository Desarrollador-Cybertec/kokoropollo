Options -Indexes
RewriteEngine On

# ── Forzar HTTPS ─────────────────────────────────────────────────────────────
# Sin esto, el cookie de sesión (secure=true) nunca se envía en HTTP,
# lo que provoca un loop infinito de redirección → ERR_TOO_MANY_REDIRECTS.
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Permitir acceso directo a archivos reales (css, img, js)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás pasa por index.php
RewriteRule ^ index.php [QSA,L]

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS — sin includeSubDomains para no afectar otros subdominios del hosting
    Header always set Strict-Transport-Security "max-age=31536000"
    # Permissions Policy
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # CSP — incluye cdnjs.cloudflare.com para Font Awesome (CSS + fuentes)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.tailwindcss.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
    # Eliminar header obsoleto X-XSS-Protection (reemplazado por CSP)
    Header always unset X-XSS-Protection
</IfModule>
