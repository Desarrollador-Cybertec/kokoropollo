Options -Indexes
DirectorySlash Off
RewriteEngine On

# C-08: Bloquear acceso directo a archivos y directorios sensibles
RedirectMatch 403 (?i)^/\.env(\..*)?$
RedirectMatch 403 (?i)^/\.git(/.*)?$
# Permitir rutas MVC bajo /config (panel), pero bloquear archivos internos reales
RedirectMatch 403 (?i)^/(app|database|storage|backups|vendor)(/.*)?$
RedirectMatch 403 (?i)^/config/.*\.php$
RedirectMatch 403 (?i)^/config/.*\.(ini|ya?ml|json|env|dist)$
RedirectMatch 403 (?i)^/composer\.(json|lock)$

# Si existe archivo real en la raiz, servirlo tal cual (NO directorios: config/, app/, etc. deben llegar a index.php)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Si existe en /public (css/js/img), redirigir internamente
RewriteCond %{DOCUMENT_ROOT}/public/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/public/$1 -d
RewriteRule ^(.*)$ public/$1 [L]

# Todo lo demas entra por el front controller
RewriteRule ^$ public/index.php [QSA,L]
RewriteRule ^(.+)$ public/index.php [QSA,L]
